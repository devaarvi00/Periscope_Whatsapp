# App
APP_NAME=Periskope WhatsApp CRM
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=change-me-to-a-secure-random-32-char-string

# Database (MySQL)
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/whatsapp_periscope

# WAHA WhatsApp provider (run: docker run -it -e WHATSAPP_DEFAULT_ENGINE=WEBJS devlikeapro/waha)
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=your-waha-api-key
WAHA_SESSION_NAME=default
WAHA_WEBHOOK_SECRET=replace-with-strong-secret

# Public URL for WAHA to POST webhooks to (use ngrok for local dev)
PUBLIC_WEBHOOK_BASE_URL=http://localhost:8000

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-lite

# Human simulation (typing indicator before sending)
WAHA_HUMAN_SIMULATION_ENABLED=true
WAHA_TYPING_MIN_SECONDS=1.0
WAHA_TYPING_MAX_SECONDS=4.0
WAHA_TYPING_CHARS_PER_SECOND=14.0

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Platform limits
REQUEST_TIMEOUT_SECONDS=30
BULK_MESSAGE_CREDITS_PER_MONTH=3000
MAX_AUTOMATION_RULES_PER_LICENSE=2

# Logging
LOG_LEVEL=INFO
