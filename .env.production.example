# ── App ────────────────────────────────────────────────────────────
APP_NAME=Periskope WhatsApp CRM
ENVIRONMENT=production
DEBUG=false

# CHANGE THIS — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── Database ────────────────────────────────────────────────────────
# Used by docker-compose to set the MySQL root password
MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# Set automatically by docker-compose using MYSQL_ROOT_PASSWORD above
# DATABASE_URL=mysql+pymysql://root:PASSWORD@mysql:3306/whatsapp_periscope

# ── WAHA ────────────────────────────────────────────────────────────
WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=REPLACE_WITH_STRONG_WAHA_KEY
WAHA_SESSION_NAME=default
WAHA_WEBHOOK_SECRET=REPLACE_WITH_STRONG_WEBHOOK_SECRET

# Your public domain — WAHA container POSTs webhooks here
PUBLIC_WEBHOOK_BASE_URL=https://YOUR_DOMAIN.com

# ── Google Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=your-real-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── CORS ────────────────────────────────────────────────────────────
# Restrict to your domain in production
ALLOWED_ORIGINS=["https://YOUR_DOMAIN.com"]

# ── Human simulation ────────────────────────────────────────────────
WAHA_HUMAN_SIMULATION_ENABLED=true
WAHA_TYPING_MIN_SECONDS=1.0
WAHA_TYPING_MAX_SECONDS=4.0
WAHA_TYPING_CHARS_PER_SECOND=14.0

# ── Auth ────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Limits ────────────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30
BULK_MESSAGE_CREDITS_PER_MONTH=3000
MAX_AUTOMATION_RULES_PER_LICENSE=20

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=WARNING
